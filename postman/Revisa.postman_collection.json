              ],
              "path": [
                "conteudos",
                "{{conteudoId}}",
                "reativar"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "04 - Filtros e Dashboard",
      "item": [
        {
          "name": "Filtrar por domínio válido",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/conteudos/por-dominio?nivel=4",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "conteudos",
                "por-dominio"
              ],
              "query": [
                {
                  "key": "nivel",
                  "value": "4"
                }
              ]
            }
          }
        },
        {
          "name": "Filtrar por domínio inválido",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Domínio inválido retorna erro', function () {",
                  "  pm.response.to.have.status(400);",
                  "  pm.expect(pm.response.text()).to.include('Nível de domínio deve estar entre 1 e 5');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/conteudos/por-dominio?nivel=8",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "conteudos",
                "por-dominio"
              ],
              "query": [
                {
                  "key": "nivel",
                  "value": "8"
                }
              ]
            }
          }
        },
        {
          "name": "Filtrar por período",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/conteudos/periodo?inicio=2026-05-01&fim=2026-05-31",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "conteudos",
                "periodo"
              ],
              "query": [
                {
                  "key": "inicio",
                  "value": "2026-05-01"
                },
                {
                  "key": "fim",
                  "value": "2026-05-31"
                }
              ]
            }
          }
        },
        {
          "name": "Dashboard",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/dashboard",
