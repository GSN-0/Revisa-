{
  "info": {
    "name": "Revisa - Fluxo Principal",
    "description": "Coleção organizada por fluxo: cadastro, login, matéria, conteúdo, revisão, conclusão, filtros e dashboard.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "materiaId",
      "value": ""
    },
    {
      "key": "conteudoId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "01 - Autenticação",
      "item": [
        {
          "name": "Cadastrar usuário de teste",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Usuário Teste\",\n  \"email\": \"teste@gmail.com\",\n  \"senha\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login retornou token', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.token).to.be.a('string').and.not.empty;",
                  "  pm.collectionVariables.set('token', json.token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"teste@gmail.com\",\n  \"senha\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "02 - Matérias",
      "item": [
        {
          "name": "Criar matéria - Java",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Matéria criada', function () {",
                  "  pm.response.to.have.status(201);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.id).to.exist;",
                  "  pm.collectionVariables.set('materiaId', json.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Java e Spring\",\n  \"descricao\": \"Estudos de Java, Spring Boot, APIs REST e segurança.\",\n  \"cor\": \"#2563EB\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/materias",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "materias"
              ]
            }
          }
        },
        {
          "name": "Listar matérias",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/materias",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "materias"
              ]
            }
          }
        },
        {
          "name": "Listar matérias paginado",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/materias?page=0&size=10&sort=nome,asc",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "materias"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                },
                {
                  "key": "sort",
                  "value": "nome,asc"
                }
              ]
            }
          }
        },
        {
          "name": "Resumo por matéria",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/materias/{{materiaId}}/resumo",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "materias",
                "{{materiaId}}",
                "resumo"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "03 - Conteúdos",
      "item": [
        {
          "name": "Criar conteúdo - Spring Security",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Conteúdo criado', function () {",
                  "  pm.response.to.have.status(201);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.id).to.exist;",
                  "  pm.collectionVariables.set('conteudoId', json.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Spring Security com JWT\",\n  \"descricao\": \"Estudei autenticação, filtros e geração de token JWT.\",\n  \"dataEstudo\": \"2026-05-05\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/materias/{{materiaId}}/conteudos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "materias",
                "{{materiaId}}",
                "conteudos"
              ]
            }
          }
        },
        {
          "name": "Listar todos os conteúdos",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/conteudos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "conteudos"
              ]
            }
          }
        },
        {
          "name": "Listar conteúdos paginado",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/conteudos?page=0&size=10&sort=proximaRevisao,asc",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "conteudos"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                },
                {
                  "key": "sort",
                  "value": "proximaRevisao,asc"
                }
              ]
            }
          }
        },
        {
          "name": "Registrar evolução",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nivelDominio\": 4,\n  \"observacaoEvolucao\": \"Entendi autenticação e filtros, mas ainda preciso revisar permissões.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/conteudos/{{conteudoId}}/evolucao",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "conteudos",
                "{{conteudoId}}",
                "evolucao"
              ]
            }
          }
        },
        {
          "name": "Revisar conteúdo",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
