                }
              ]
            },
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/conteudos/{{conteudoId}}/revisar",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "conteudos",
                "{{conteudoId}}",
                "revisar"
              ]
            }
          }
        },
        {
          "name": "Listar revisões pendentes",
          "request": {
            "auth": {
