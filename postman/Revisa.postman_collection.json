              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/conteudos/pendentes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "conteudos",
                "pendentes"
              ]
            }
          }
        },
        {
          "name": "Concluir conteúdo",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/conteudos/{{conteudoId}}/concluir",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "conteudos",
                "{{conteudoId}}",
                "concluir"
              ]
            }
          }
        },
        {
          "name": "Reativar conteúdo",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/conteudos/{{conteudoId}}/reativar",
